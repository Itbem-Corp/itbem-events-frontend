---
import "../styles/global.css";
import "../styles/fonts.css";
import { eventsUrlOrigin } from "../lib/eventsUrl";
import { sanitizePublicShareUrl } from "../lib/publicShareUrl";

interface Props {
  title: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  language?: string;
}

const {
  title,
  ogTitle       = title,
  ogDescription = 'Tu invitación digital',
  ogImage       = '',
  ogUrl         = '',
  language      = 'es',
} = Astro.props;

const apiOrigin = eventsUrlOrigin(import.meta.env.PUBLIC_EVENTS_URL as string | undefined);
const cloudflareAnalyticsEnabled = import.meta.env.PROD;

function normalizeLanguage(value: string): string {
  const trimmed = value.trim().toLowerCase();
  if (!trimmed) return 'es';
  return trimmed.replace(/_/g, '-');
}

function ogLocaleForLanguage(value: string): string {
  const lang = normalizeLanguage(value);
  if (lang.startsWith('en')) return 'en_US';
  if (lang.startsWith('es')) return 'es_MX';
  return lang.replace(/-/g, '_');
}

const htmlLanguage = normalizeLanguage(language);
const ogLocale = ogLocaleForLanguage(htmlLanguage);
// SSR routes can receive preview, invitation, and access credentials in the
// query string. Open Graph metadata is public/shareable, so it must never echo
// those credentials even when an individual page passes Astro.url.href.
const publicOgUrl = ogUrl ? sanitizePublicShareUrl(ogUrl) : '';
---

<!DOCTYPE html>
<html lang={htmlLanguage} class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fbfaf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#102f3f" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="EventiApp" />
    <link rel="apple-touch-icon" href="/icons/pwa-192.png" />
    <!-- Preload only the two fonts used by the initial public shell. -->
    <link rel="preload" href="/fonts/Bigilla.otf" as="font" type="font/otf" crossorigin>
    <link rel="preload" href="/fonts/Quicksand-VariableFont_wght.ttf" as="font" type="font/ttf" crossorigin>

    <!-- Preconnect to AWS S3 -->
    <link rel="preconnect" href="https://itbem-events-bucket-prod.s3.us-east-2.amazonaws.com" crossorigin>

    <!-- Preconnect to Google Maps -->
    <link rel="preconnect" href="https://maps.googleapis.com" crossorigin>
    <link rel="dns-prefetch" href="https://maps.googleapis.com">

    <!-- Preconnect to API (DNS + TCP + TLS warmup) -->
    {apiOrigin && <link rel="preconnect" href={apiOrigin} crossorigin>}
    {apiOrigin && <link rel="dns-prefetch" href={apiOrigin}>}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO -->
    <meta name="description" content={ogDescription} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EventiApp" />
    <meta property="og:locale" content={ogLocale} />
    {publicOgUrl && <meta property="og:url" content={publicOgUrl} />}
    {ogImage && <meta property="og:image"          content={ogImage} />}
    {ogImage && <meta property="og:image:alt"      content={ogTitle} />}
    {ogImage && <meta property="og:image:width"    content="1200" />}
    {ogImage && <meta property="og:image:height"   content="630" />}
    {ogImage && <meta property="og:image:type"     content="image/png" />}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title"       content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <!-- Cloudflare Web Analytics is production-only; local development stays private and quiet. -->
    {cloudflareAnalyticsEnabled && (
      <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js"
              data-cf-beacon='{"token": "07475d5be6a94add96c6e02ec0fab176"}'></script>
    )}
  </head>
  <body class="eventi-app-shell">
    <slot />

    <!-- Content protection: right-click + drag block (applies to all pages) -->
    <script>
      document.addEventListener('contextmenu', (e) => {
        if (e.target instanceof HTMLImageElement || e.target instanceof HTMLVideoElement) {
          e.preventDefault()
        }
      }, { capture: true })

      document.addEventListener('dragstart', (e) => {
        if (e.target instanceof HTMLImageElement) e.preventDefault()
      }, { capture: true })
    </script>
  </body>
</html>
