---
export const prerender = false;

/**
 * RSVP portal page — /rsvp/{identifier}
 * Loads the same SDUI EventPage but auto-scrolls to the RSVPConfirmation section.
 * Used by the dashboard when sharing RSVP links via WhatsApp/Email.
 */
import TemplateLayout from '../../layouts/template.astro';
import EventPage from '../../components/engine/EventPage';
import { fetchEventOgData, buildOgImageUrl } from '../../lib/og';

const EVENTS_URL = import.meta.env.PUBLIC_EVENTS_URL as string;
const { identifier } = Astro.params;

let ogTitle = 'Confirma tu asistencia';
let ogDesc  = 'Te esperamos. Confirma en un tap y no te pierdas ningún detalle.';
let ogImage = '';
const ogUrl = Astro.url.href;

if (identifier) {
  const ev = await fetchEventOgData(EVENTS_URL, identifier);
  if (ev) {
    ogTitle = ev.name ? `Confirma | ${ev.name}` : ogTitle;

    if (ev.organizer_name) {
      ogDesc = `${ev.organizer_name} te espera. Confirma tu asistencia en segundos.`;
    }

    ogImage = buildOgImageUrl({
      title: ev.name,
      date: ev.event_date_time,
      address: ev.address,
      cover: ev.cover_image_url,
      type: ev.event_type,
    });
  }
}
---

<TemplateLayout
  title={ogTitle}
  ogTitle={ogTitle}
  ogDescription={ogDesc}
  ogImage={ogImage}
  ogUrl={ogUrl}
>
  <EventPage
    client:only="react"
    EVENTS_URL={EVENTS_URL}
    identifier={identifier}
    rsvpMode={true}
  />
</TemplateLayout>
