---
export const prerender = false;

/**
 * Generic event page — zero-code route for new events.
 * Fetches event metadata server-side (Astro SSR) for OG tags so
 * WhatsApp / Telegram / iMessage show rich link previews.
 */
import TemplateLayout from '../layouts/template.astro';
import EventPage from '../components/engine/EventPage';
import { buildOgImageUrl, fetchInvitationOgData } from '../lib/og';
import { normalizeEventsUrl } from '../lib/eventsUrl';
import { readPublicAccessParams } from '../lib/publicPreview';

const EVENTS_URL = normalizeEventsUrl(import.meta.env.PUBLIC_EVENTS_URL as string | undefined);

// Read token from query string at SSR time
const token = readPublicAccessParams(Astro.url.search).invitationToken;

// Fetch invitation data server-side for OG meta (best-effort, 3s timeout)
let ogTitle   = 'Estás invitado';
let ogDesc    = 'Abre tu invitación y descubre todos los detalles del evento.';
let ogImage   = '';
let pageLanguage = 'es';
const ogUrl   = Astro.url.href;

if (token) {
  try {
    const ev = await fetchInvitationOgData(EVENTS_URL, token);
    if (ev) {
      if (ev.name) ogTitle = ev.name;
      if (ev.description) {
        ogDesc = ev.description.slice(0, 160);
      } else if (ev.organizer_name || ev.address) {
        ogDesc = [ev.organizer_name ? `${ev.organizer_name} te invita` : '', ev.address ?? ''].filter(Boolean).join(' · ');
      }
      ogImage = buildOgImageUrl({
        title: ev.name || ogTitle,
        date: ev.event_date_time,
        timezone: ev.timezone,
        language: ev.language,
        address: ev.address || ev.second_address,
        cover: ev.cover_view_url || ev.view_url || ev.cover_image_url,
        type: ev.event_type,
        eventsUrl: EVENTS_URL,
      });
      pageLanguage = ev.language ?? pageLanguage;
    }
  } catch {
    // Fail silently — page works fine without OG tags
  }
}
---

<TemplateLayout
  title={ogTitle}
  ogTitle={ogTitle}
  ogDescription={ogDesc}
  ogImage={ogImage}
  ogUrl={ogUrl}
  language={pageLanguage}
>
  <EventPage
    client:only="react"
    EVENTS_URL={EVENTS_URL}
  />
</TemplateLayout>
