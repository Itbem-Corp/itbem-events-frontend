---
/**
 * Dynamic upload page - /events/{identifier}/upload.
 * Fetches event data server-side for rich OG previews when shared.
 */
export const prerender = false

import TemplateLayout from '../../../layouts/template.astro'
import SharedUploadPage from '../../../components/SharedUploadPage'
import { buildSharedUploadOgMeta, fetchEventOgData } from '../../../lib/og'
import { normalizeEventsUrl } from '../../../lib/eventsUrl'
import { normalizePathIdentifier } from '../../../lib/pathIdentifier'
import { readPublicAccessParams } from '../../../lib/publicPreview'

const EVENTS_URL = normalizeEventsUrl(import.meta.env.PUBLIC_EVENTS_URL as string | undefined)
const identifier = normalizePathIdentifier(Astro.params.identifier)
const accessParams = readPublicAccessParams(Astro.url.search)
const ogUrl = Astro.url.href

const eventOg = identifier
  ? await fetchEventOgData(
      EVENTS_URL,
      identifier,
      accessParams.previewToken,
      accessParams.cacheKey,
      accessParams.invitationToken,
      accessParams.accessToken
    )
  : null
const ogMeta = buildSharedUploadOgMeta(eventOg, EVENTS_URL)
---

<TemplateLayout
  title={ogMeta.title}
  ogTitle={ogMeta.title}
  ogDescription={ogMeta.description}
  ogImage={ogMeta.image}
  ogUrl={ogUrl}
  language={eventOg?.language}
>
  <SharedUploadPage
    client:only="react"
    EVENTS_URL={EVENTS_URL}
  />
</TemplateLayout>
