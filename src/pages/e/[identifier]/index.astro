---
export const prerender = false;

/**
 * Public event page - /e/{identifier}.
 * Loads the SDUI PageSpec by event identifier.
 */
import TemplateLayout from '../../../layouts/template.astro';
import EventPage from '../../../components/engine/EventPage';
import PublicEventShell from '../../../components/public/PublicEventShell.astro';
import { buildPublicEventOgMeta, fetchEventOgData } from '../../../lib/og';
import { normalizeEventsUrl } from '../../../lib/eventsUrl';
import { normalizePathIdentifier } from '../../../lib/pathIdentifier';
import { readPublicAccessParams } from '../../../lib/publicPreview';
import { fetchPublicEventShell } from '../../../lib/publicEventShell';

const EVENTS_URL = normalizeEventsUrl(import.meta.env.PUBLIC_EVENTS_URL as string | undefined);
const identifier = normalizePathIdentifier(Astro.params.identifier);
const accessParams = readPublicAccessParams(Astro.url.search);
const ogUrl = Astro.url.href;
const hasCredential = Boolean(
  accessParams.previewToken ||
  accessParams.cacheKey ||
  accessParams.invitationToken ||
  accessParams.accessToken
);

// Preview/invitation/access proofs are consumed only by the client. Their
// PageSpec and metadata never enter SSR HTML, even on a no-store response.
const [eventOg, serverShellSpec] = identifier && !hasCredential
  ? await Promise.all([
      fetchEventOgData(
        EVENTS_URL,
        identifier,
      ),
      fetchPublicEventShell({
        eventsUrl: EVENTS_URL,
        identifier,
      }),
    ])
  : [null, null];
const ogMeta = buildPublicEventOgMeta(eventOg, EVENTS_URL);
---

<TemplateLayout
  title={ogMeta.title}
  ogTitle={ogMeta.title}
  ogDescription={ogMeta.description}
  ogImage={ogMeta.image}
  ogUrl={ogUrl}
  language={eventOg?.language}
  preloadFonts="invitation"
>
  {serverShellSpec && (
    <PublicEventShell spec={serverShellSpec} eventsUrl={EVENTS_URL} />
  )}
  <EventPage
    client:only="react"
    EVENTS_URL={EVENTS_URL}
    identifier={identifier}
  />
</TemplateLayout>
