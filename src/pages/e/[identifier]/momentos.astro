---
export const prerender = false

import TemplateLayout from '../../../layouts/template.astro'
import MomentsGallery from '../../../components/moments/MomentsGallery'
import { fetchEventOgData, buildOgImageUrl } from '../../../lib/og'

const EVENTS_URL = import.meta.env.PUBLIC_EVENTS_URL as string ?? 'http://localhost:8080/'
const { identifier } = Astro.params
// Admin preview token — passed from dashboard, validated by backend on each request.
const previewToken = Astro.url.searchParams.get('preview_token') ?? ''

let ogTitle = 'Momentos del evento'
let ogDesc  = 'Las mejores fotos y videos del evento. Revive cada momento.'
let ogImage = ''
const ogUrl = Astro.url.href

if (identifier) {
  const ev = await fetchEventOgData(EVENTS_URL, identifier)
  if (ev) {
    ogTitle = ev.name ? `Momentos — ${ev.name}` : ogTitle

    if (ev.organizer_name) {
      ogDesc = `Galeria de fotos y videos de ${ev.name}. Revive los mejores momentos.`
    }

    ogImage = buildOgImageUrl({
      title: `Momentos — ${ev.name}`,
      cover: ev.cover_image_url,
      type: ev.event_type,
    })
  }
}
---

<TemplateLayout
  title={ogTitle}
  ogTitle={ogTitle}
  ogDescription={ogDesc}
  ogImage={ogImage}
  ogUrl={ogUrl}
>
  <MomentsGallery
    client:only="react"
    EVENTS_URL={EVENTS_URL}
    previewToken={previewToken}
  />

  <!-- Black shield: covers content when app goes to background (recent-apps  -->
  <!-- screenshot on iOS/Android, desktop screen-share detection).            -->
  <!-- Only active on the moments wall — NOT on upload or RSVP pages.         -->
  <script is:inline>
    (function () {
      var shield = document.createElement('div')
      shield.setAttribute('aria-hidden', 'true')
      shield.style.cssText = 'position:fixed;inset:0;background:#000;z-index:2147483647;display:none;pointer-events:none'
      document.body.appendChild(shield)

      function show() { shield.style.display = 'block' }
      function hide() { shield.style.display = 'none'  }

      // visibilitychange: tab-switch, minimise, Android app-switcher
      document.addEventListener('visibilitychange', function () {
        document.hidden ? show() : hide()
      })
      // pagehide/pageshow: iOS Safari backgrounding / back-forward cache
      window.addEventListener('pagehide', show)
      window.addEventListener('pageshow', hide)
      // NOTE: blur/focus intentionally omitted — fires on DevTools open,
      // OS popups, and any window losing focus, causing false positives.
    })()
  </script>
</TemplateLayout>
