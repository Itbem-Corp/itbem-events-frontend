---
export const prerender = false;

import TemplateLayout from '../../../layouts/template.astro';
import MomentsGallery from '../../../components/moments/MomentsGallery';
import { buildMomentsOgMeta, fetchEventOgData } from '../../../lib/og';
import { normalizeEventsUrl } from '../../../lib/eventsUrl';
import { normalizePathIdentifier } from '../../../lib/pathIdentifier';
import { readPublicAccessParams } from '../../../lib/publicPreview';

const EVENTS_URL = normalizeEventsUrl(import.meta.env.PUBLIC_EVENTS_URL as string | undefined);
const identifier = normalizePathIdentifier(Astro.params.identifier);
const accessParams = readPublicAccessParams(Astro.url.search);
const ogUrl = Astro.url.href;

const eventOg = identifier
  ? await fetchEventOgData(
      EVENTS_URL,
      identifier,
      accessParams.previewToken,
      accessParams.cacheKey,
      accessParams.invitationToken,
      accessParams.accessToken
    )
  : null;
const ogMeta = buildMomentsOgMeta(eventOg, EVENTS_URL);
const publicMomentsCacheKey = accessParams.cacheKey || eventOg?.content_version || "";
const momentsPublicAccess = {
  previewToken: accessParams.previewToken,
  cacheKey: publicMomentsCacheKey,
  sendCacheKey: Boolean(publicMomentsCacheKey && !accessParams.cacheKey),
  invitationToken: accessParams.invitationToken,
  accessToken: accessParams.accessToken ?? "",
};
---

<TemplateLayout
  title={ogMeta.title}
  ogTitle={ogMeta.title}
  ogDescription={ogMeta.description}
  ogImage={ogMeta.image}
  ogUrl={ogUrl}
  language={eventOg?.language}
>
  <MomentsGallery
    client:only="react"
    EVENTS_URL={EVENTS_URL}
    previewToken={accessParams.previewToken}
    publicAccess={momentsPublicAccess}
  />

  <!-- Black shield: covers content when app goes to background. -->
  <!-- Only active on the moments wall, not on upload or RSVP pages. -->
  <script is:inline>
    (function () {
      var shield = document.createElement('div')
      shield.setAttribute('aria-hidden', 'true')
      shield.style.cssText = 'position:fixed;inset:0;background:#000;z-index:2147483647;display:none;pointer-events:none'
      document.body.appendChild(shield)

      function show() { shield.style.display = 'block' }
      function hide() { shield.style.display = 'none'  }

      document.addEventListener('visibilitychange', function () {
        document.hidden ? show() : hide()
      })
      window.addEventListener('pagehide', show)
      window.addEventListener('pageshow', hide)
    })()
  </script>
</TemplateLayout>
