---
export const prerender = false

import TemplateLayout from '../../../layouts/template.astro'
import TvSlideshow from '../../../components/moments/TvSlideshow'
import { buildTvOgMeta, fetchEventOgData } from '../../../lib/og'
import { normalizeEventsUrl } from '../../../lib/eventsUrl'
import { normalizePathIdentifier } from '../../../lib/pathIdentifier'
import { readPublicAccessParams } from '../../../lib/publicPreview'

const EVENTS_URL = normalizeEventsUrl(import.meta.env.PUBLIC_EVENTS_URL as string | undefined)
const identifier = normalizePathIdentifier(Astro.params.identifier)
const accessParams = readPublicAccessParams(Astro.url.search)
const previewToken = accessParams.previewToken

let ogTitle = 'Slideshow del evento'
let ogDesc  = 'Modo TV — disfruta los momentos del evento en pantalla completa.'
let pageLanguage = 'es'
let ogImage = ''
const ogUrl = Astro.url.href
let publicContentVersion = ''

if (identifier) {
  const ev = await fetchEventOgData(
    EVENTS_URL,
    identifier,
    previewToken,
    accessParams.cacheKey,
    accessParams.invitationToken,
    accessParams.accessToken
  )
  if (ev) {
    ogTitle = ev.name ? `Slideshow — ${ev.name}` : ogTitle

    const meta = buildTvOgMeta(ev, EVENTS_URL)
    ogTitle = meta.title
    ogDesc = meta.description
    ogImage = meta.image
    pageLanguage = ev.language ?? pageLanguage
    publicContentVersion = ev.content_version ?? ''
  }
}

const tvCacheKey = accessParams.cacheKey || publicContentVersion
const tvPublicAccess = {
  previewToken,
  cacheKey: tvCacheKey,
  sendCacheKey: Boolean(tvCacheKey && !accessParams.cacheKey),
  invitationToken: accessParams.invitationToken,
  accessToken: accessParams.accessToken ?? '',
}
---

<TemplateLayout
  title={ogTitle}
  ogTitle={ogTitle}
  ogDescription={ogDesc}
  ogImage={ogImage}
  ogUrl={ogUrl}
  language={pageLanguage}
>
  <TvSlideshow
    client:only="react"
    EVENTS_URL={EVENTS_URL}
    previewToken={previewToken}
    publicAccess={tvPublicAccess}
  />

  <style is:global>
    body { overflow: hidden; background: #000; }
  </style>

  <script is:inline>
    ;(function () {
      var t
      document.addEventListener('mousemove', function () {
        document.body.style.cursor = 'default'
        clearTimeout(t)
        t = setTimeout(function () { document.body.style.cursor = 'none' }, 3000)
      })
    })()
  </script>
</TemplateLayout>
