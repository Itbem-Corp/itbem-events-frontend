---
/**
 * Lightweight offline fallback. It stays framework-free because Workbox may
 * need to serve it before any application JavaScript is available.
 */
export const prerender = true;

import TemplateLayout from '../layouts/template.astro';
---

<TemplateLayout title="Sin conexión — EventiApp">
  <main class="eventi-offline-shell" data-offline-state>
    <div class="eventi-offline-glow eventi-offline-glow--brand" aria-hidden="true"></div>
    <div class="eventi-offline-glow eventi-offline-glow--ink" aria-hidden="true"></div>

    <section class="eventi-offline-card" aria-labelledby="offline-title" aria-describedby="offline-description">
      <div class="eventi-offline-copy">
        <div class="eventi-offline-brand">
          <span class="eventi-offline-mark" aria-hidden="true">
            <img src="/favicon.svg" alt="" width="28" height="28" decoding="async" />
          </span>
          <span>EventiApp</span>
        </div>

        <p class="eventi-eyebrow">Conexión interrumpida</p>
        <h1 id="offline-title">Tu experiencia sigue aquí.</h1>
        <p id="offline-description" class="eventi-offline-description">
          No pudimos conectar en este momento. Si ya abriste tu invitación en este dispositivo,
          puedes volver a ella desde el historial cuando recupere la señal.
        </p>

        <div class="eventi-offline-actions">
          <button class="eventi-offline-primary" type="button" data-retry>
            <span data-retry-label>Reintentar conexión</span>
            <span aria-hidden="true">→</span>
          </button>
          <a class="eventi-offline-secondary" href="/">Ir al inicio</a>
        </div>

        <p class="eventi-offline-status" role="status" aria-live="polite" data-status>
          Revisaremos la conexión cuando pulses reintentar.
        </p>
      </div>

      <aside class="eventi-offline-aside" aria-label="Qué puedes hacer mientras tanto">
        <div class="eventi-offline-aside-mark" aria-hidden="true">
          <img src="/favicon.svg" alt="" width="58" height="58" decoding="async" />
        </div>
        <p class="eventi-offline-aside-kicker">Mientras vuelve la señal</p>
        <h2>No perderás el enlace que recibiste.</h2>
        <ul>
          <li>Permanece en esta página y vuelve a intentarlo.</li>
          <li>Comprueba tus datos móviles o la red Wi-Fi.</li>
          <li>Evita abrir enlaces nuevos hasta recuperar conexión.</li>
        </ul>
      </aside>
    </section>

    <footer class="eventi-offline-footer">
      <span>Tu invitación digital</span>
      <span aria-hidden="true">EA / OFFLINE</span>
    </footer>
  </main>

  <script>
    const root = document.querySelector<HTMLElement>('[data-offline-state]');
    const retry = root?.querySelector<HTMLButtonElement>('[data-retry]');
    const retryLabel = root?.querySelector<HTMLElement>('[data-retry-label]');
    const status = root?.querySelector<HTMLElement>('[data-status]');

    const renderConnection = () => {
      if (!status) return;
      status.textContent = navigator.onLine
        ? 'La señal volvió. Ya puedes reintentar.'
        : 'Aún no detectamos conexión. Tu enlace permanece en el navegador.';
    };

    window.addEventListener('online', renderConnection);
    window.addEventListener('offline', renderConnection);

    retry?.addEventListener('click', () => {
      if (retry.disabled) return;
      retry.disabled = true;
      retry.setAttribute('aria-busy', 'true');
      if (retryLabel) retryLabel.textContent = 'Comprobando…';
      if (status) status.textContent = 'Comprobando la conexión…';

      if (navigator.onLine) {
        window.location.reload();
        return;
      }

      window.setTimeout(() => {
        retry.disabled = false;
        retry.removeAttribute('aria-busy');
        if (retryLabel) retryLabel.textContent = 'Reintentar conexión';
        renderConnection();
      }, 700);
    });
  </script>
</TemplateLayout>

<style>
  .eventi-offline-shell {
    position: relative;
    display: grid;
    min-height: 100svh;
    width: 100%;
    place-items: center;
    overflow: hidden;
    padding: clamp(1rem, 4vw, 3.5rem);
    color: var(--eventi-ink);
    background: var(--eventi-canvas);
  }

  .eventi-offline-glow {
    position: absolute;
    width: min(42rem, 70vw);
    aspect-ratio: 1;
    border-radius: 999px;
    filter: blur(10px);
    pointer-events: none;
  }

  .eventi-offline-glow--brand {
    top: -30%;
    left: -12%;
    background: radial-gradient(circle, rgba(221, 34, 132, 0.12), transparent 68%);
  }

  .eventi-offline-glow--ink {
    right: -14%;
    bottom: -38%;
    background: radial-gradient(circle, rgba(16, 47, 63, 0.13), transparent 68%);
  }

  .eventi-offline-card {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(100%, 68rem);
    overflow: hidden;
    border: 1px solid var(--eventi-line);
    border-radius: clamp(1.5rem, 3vw, 2.25rem);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 28px 90px -48px rgba(16, 47, 63, 0.55);
  }

  .eventi-offline-copy,
  .eventi-offline-aside {
    padding: clamp(1.75rem, 5vw, 4.5rem);
  }

  .eventi-offline-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: clamp(3rem, 8vw, 6rem);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eventi-offline-mark {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 1px solid rgba(221, 34, 132, 0.14);
    border-radius: 0.9rem;
    background: var(--eventi-brand-soft);
  }

  h1 {
    max-width: 10ch;
    margin: 0.75rem 0 1rem;
    font-size: clamp(2.35rem, 6vw, 4.7rem);
    font-weight: 650;
    letter-spacing: -0.065em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .eventi-offline-description {
    max-width: 36rem;
    margin: 0;
    color: var(--eventi-ink-muted);
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    line-height: 1.75;
  }

  .eventi-offline-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .eventi-offline-primary,
  .eventi-offline-secondary {
    display: inline-flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border-radius: 1rem;
    padding: 0.85rem 1.15rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .eventi-offline-primary {
    min-width: 13rem;
    border: 0;
    color: #fff;
    background: linear-gradient(120deg, var(--eventi-brand), #a429b8 54%, #4b4bdd);
    box-shadow: 0 18px 34px -20px rgba(142, 42, 181, 0.72);
    cursor: pointer;
  }

  .eventi-offline-primary:hover:not(:disabled),
  .eventi-offline-secondary:hover {
    transform: translateY(-2px);
  }

  .eventi-offline-primary:disabled {
    opacity: 0.72;
    cursor: wait;
  }

  .eventi-offline-secondary {
    border: 1px solid var(--eventi-line);
    color: var(--eventi-ink);
    background: #fff;
  }

  .eventi-offline-status {
    min-height: 1.5rem;
    margin: 1rem 0 0;
    color: var(--eventi-ink-muted);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .eventi-offline-aside {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #fff;
    background:
      radial-gradient(circle at 85% 8%, rgba(221, 34, 132, 0.42), transparent 16rem),
      linear-gradient(145deg, #0b2736, #123c50);
  }

  .eventi-offline-aside-mark {
    display: grid;
    width: 6rem;
    height: 6rem;
    place-items: center;
    margin-bottom: auto;
    border-radius: 2rem;
    background: linear-gradient(145deg, var(--eventi-brand), #ba166d);
    box-shadow: 0 24px 54px -28px rgba(221, 34, 132, 0.9);
  }

  .eventi-offline-aside-kicker {
    margin: 4rem 0 0.75rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .eventi-offline-aside h2 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.65rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .eventi-offline-aside ul {
    display: grid;
    gap: 0.8rem;
    margin: 2rem 0 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.86rem;
    line-height: 1.55;
    list-style: none;
  }

  .eventi-offline-aside li {
    position: relative;
    padding-left: 1.25rem;
  }

  .eventi-offline-aside li::before {
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: var(--eventi-brand);
    content: '';
  }

  .eventi-offline-footer {
    position: absolute;
    right: clamp(1rem, 4vw, 3.5rem);
    bottom: max(0.75rem, env(safe-area-inset-bottom));
    left: clamp(1rem, 4vw, 3.5rem);
    z-index: 1;
    display: flex;
    justify-content: space-between;
    color: rgba(16, 47, 63, 0.54);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 820px) {
    .eventi-offline-card {
      grid-template-columns: minmax(0, 1.16fr) minmax(20rem, 0.84fr);
      min-height: min(44rem, calc(100svh - 7rem));
    }
  }

  @media (max-width: 819px) {
    .eventi-offline-shell {
      align-items: start;
      padding-bottom: 4.5rem;
    }

    .eventi-offline-card {
      max-width: 34rem;
    }

    .eventi-offline-aside {
      display: none;
    }

    .eventi-offline-brand {
      margin-bottom: clamp(3rem, 17vw, 6rem);
    }
  }

  @media (max-width: 480px) {
    .eventi-offline-actions {
      display: grid;
    }

    .eventi-offline-primary,
    .eventi-offline-secondary {
      width: 100%;
    }

    .eventi-offline-footer span:last-child {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eventi-offline-primary,
    .eventi-offline-secondary {
      transition: none;
    }
  }
</style>
