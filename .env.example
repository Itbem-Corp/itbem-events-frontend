# itbem-events-frontend environment template.
# Copy to .env and fill in your values. Never commit .env.

# HTTP port used by `npm start` / `npm run preview` (default 4321).
# Astro development also defaults to 4321.
PORT=4321

# Backend API base URL used by client-side code for API calls.
# Trailing slash and /api suffix are optional; the app normalizes both.
# Local dev:   http://localhost:8080
# Production:  https://api.eventiapp.com.mx
PUBLIC_EVENTS_URL=http://localhost:8080/

# Dashboard URL used to generate branded OG images via /api/og.
# Local dev:   http://localhost:3000
# Production:  https://dashboard.eventiapp.com.mx
PUBLIC_DASHBOARD_URL=http://localhost:3000
